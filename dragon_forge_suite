// ─── SUB-VIEWS ───

function HatcheryView({ essences, setEssences, setCollection, UI_STYLES }) {
  const [slotA, setSlotA] = useState(null);
  const [slotB, setSlotB] = useState(null);
  const [isCompiling, setIsCompiling] = useState(false);

  const compile = async () => {
    if (!slotA || !slotB) return;
    setIsCompiling(true);
    await new Promise(r => setTimeout(r, 2000));
    
    const newUnit = {
      id: `DF-${Math.floor(Math.random()*9000)+1000}`,
      name: `${slotA.toUpperCase()}_UNIT`,
      element: slotA,
      stage: 1,
      hp: 100, maxHp: 100, atk: 25
    };

    setCollection(prev => [...prev, newUnit]);
    setEssences(prev => ({ ...prev, [slotA]: prev[slotA]-5, [slotB]: prev[slotB]-5 }));
    setIsCompiling(false);
    setSlotA(null); setSlotB(null);
  };

  return (
    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "20px" }}>
      <div style={UI_STYLES.panel}>
        <div style={{ fontSize: "12px", color: "#44ff88", marginBottom: "10px" }}>// ESSENCE_INVENTORY</div>
        <div style={{ display: "flex", gap: "10px", flexWrap: "wrap" }}>
          {Object.entries(ELEMENTS).map(([key, el]) => (
            <button key={key} onClick={() => !slotA ? setSlotA(key) : setSlotB(key)} style={{ background: "#222", border: "1px solid #444", padding: "8px", color: el.color, cursor: "pointer", fontSize: "10px" }}>
              {el.emoji} {essences[key]}
            </button>
          ))}
        </div>
      </div>

      <div style={{ ...UI_STYLES.panel, textAlign: "center" }}>
        <div style={{ display: "flex", gap: "10px", justifyContent: "center", marginBottom: "20px" }}>
          <div style={{ width: "50px", height: "50px", border: "1px dashed #444", display: "flex", alignItems: "center", justifyContent: "center" }}>{slotA && ELEMENTS[slotA].emoji}</div>
          <div style={{ width: "50px", height: "50px", border: "1px dashed #444", display: "flex", alignItems: "center", justifyContent: "center" }}>{slotB && ELEMENTS[slotB].emoji}</div>
        </div>
        <button onClick={compile} disabled={isCompiling || !slotA || !slotB} style={{ background: "#44ff88", color: "#000", border: "none", padding: "10px 20px", fontWeight: "bold", cursor: "pointer", opacity: isCompiling ? 0.5 : 1 }}>
          {isCompiling ? "COMPILING..." : "INITIATE_SPLICING.SH"}
        </button>
      </div>
    </div>
  );
}

function CombatView({ playerDragon, UI_STYLES }) {
  const [state, setState] = useState('READY');
  const [enemy] = useState({ name: "WILD_UNIT", element: "ice", stage: 1, hp: 100, maxHp: 100 });
  const [pAnim, setPAnim] = useState('idle');
  const [eAnim, setEAnim] = useState('idle');

  const executeAttack = async () => {
    setState('BUSY');
    setPAnim('attack');
    await new Promise(r => setTimeout(r, 800));
    setEAnim('hit');
    await new Promise(r => setTimeout(r, 400));
    setEAnim('idle');
    setPAnim('idle');
    setState('READY');
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: "20px" }}>
      {/* ARENA WITH ELEMENTAL BACKGROUND */}
      <div style={{ 
        ...UI_STYLES.panel, 
        height: "300px", 
        backgroundImage: `url(${ELEMENTS[enemy.element].bg})`,
        backgroundSize: "cover",
        position: "relative",
        display: "flex",
        justifyContent: "space-around",
        alignItems: "flex-end",
        paddingBottom: "40px"
      }}>
        <div style={{ position: "absolute", top: 10, left: 10, background: "rgba(0,0,0,0.7)", padding: "4px", fontSize: "9px" }}>AREA: {ELEMENTS[enemy.element].name.toUpperCase()}_ZONE</div>
        
        <DragonSprite element={playerDragon.element} stage={playerDragon.stage} state={pAnim} size={80} />
        <DragonSprite element={enemy.element} stage={enemy.stage} state={eAnim} size={80} />
      </div>

      <div style={UI_STYLES.panel}>
        <button onClick={executeAttack} disabled={state === 'BUSY'} style={{ background: "#ff4422", color: "#fff", border: "none", padding: "10px 30px", fontWeight: "bold", cursor: "pointer" }}>EXECUTE_STRIKE</button>
      </div>
    </div>
  );
}

