/**
 * ANIMATION COMPONENT
 * Handles 6-frame sprite sheet logic based on ASSET_GEN_GUIDE.md
 * Frames: 1-2 Idle, 3 Charge, 4 Attack, 5 Recoil, 6 Return
 */
const DragonSprite = ({ element, stage, state = 'idle', size = 64 }) => {
  const [frame, setFrame] = useState(0);
  const sheet = ELEMENTS[element]?.sheet || "";

  useEffect(() => {
    let interval;
    if (state === 'idle') {
      interval = setInterval(() => setFrame(f => (f === 0 ? 1 : 0)), 400); // Frames 1-2
    } else if (state === 'attack') {
      setFrame(2); // Charge
      setTimeout(() => setFrame(3), 300); // Execute
      setTimeout(() => setFrame(5), 600); // Return
    } else if (state === 'hit') {
      setFrame(4); // Recoil
    }
    return () => clearInterval(interval);
  }, [state]);

  const scale = [0.5, 0.75, 1.0, 1.4][stage - 1];

  return (
    <div style={{
      width: `${size}px`,
      height: `${size}px`,
      backgroundImage: `url(${sheet})`,
      backgroundSize: `${size * 6}px ${size}px`,
      backgroundPosition: `-${frame * size}px 0px`,
      imageRendering: 'pixelated',
      transform: `scale(${scale})`,
      filter: stage === 4 ? 'drop-shadow(0 0 5px gold)' : 'none',
      transition: 'transform 0.3s ease'
    }} />
  );
};

